generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── Generic Content Blocks (key-value JSON store) ──────────────────

model ContentBlock {
  id        String   @id @default(cuid())
  key       String   @unique
  valueJson String
  updatedAt DateTime @updatedAt
}

// ─── Blog ───────────────────────────────────────────────────────────

model BlogArticle {
  id                  String   @id @default(cuid())
  slug                String   @unique
  imageUrl            String
  day                 String
  monthEn             String
  monthAr             String
  readTimeEn          String
  readTimeAr          String
  titleEn             String
  titleAr             String
  excerptEn           String
  excerptAr           String
  bodyEn              String
  bodyAr              String
  suggestedBreakAfter Int?
  published           Boolean  @default(true)
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  // Content fields
  imageAltEn          String?
  imageAltAr          String?
  category            String?
  tags                String?
  // SEO
  metaTitleEn         String?
  metaTitleAr         String?
  metaDescriptionEn   String?
  metaDescriptionAr   String?
  ogImageUrl          String?
  keywords            String?
}

model SuggestedArticle {
  id        String @id @default(cuid())
  imageUrl  String
  titleEn   String
  titleAr   String
  slug      String
  sortOrder Int    @default(0)
}

// ─── FAQ ────────────────────────────────────────────────────────────

model FaqCategory {
  id         String    @id @default(cuid())
  nameEn     String
  nameAr     String
  sortOrder  Int       @default(0)
  isHomepage Boolean   @default(false)
  questions  FaqItem[]
}

model FaqItem {
  id         String      @id @default(cuid())
  questionEn String
  questionAr String
  answerEn   String
  answerAr   String
  sortOrder  Int         @default(0)
  categoryId String
  category   FaqCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

// ─── Plans / Account Types ──────────────────────────────────────────

model Plan {
  id              String  @id @default(cuid())
  nameEn          String
  nameAr          String
  priceEn         String
  priceAr         String
  periodEn        String
  periodAr        String
  descriptionEn   String
  descriptionAr   String
  featuresLabelEn String
  featuresLabelAr String
  ctaEn           String
  ctaAr           String
  ctaUrl          String  @default("/register")
  ctaStyle        String
  bg              String
  gradient        Boolean @default(false)
  sortOrder       Int     @default(0)
  benefitsEn      String  @default("[]")
  benefitsAr      String  @default("[]")
}

model PlanFeature {
  id        String @id @default(cuid())
  labelEn   String
  labelAr   String
  sortOrder Int    @default(0)
}

// ─── Financial Assets ───────────────────────────────────────────────

model FinancialAsset {
  id            String           @id @default(cuid())
  slug          String           @unique
  nameEn        String
  nameAr        String
  headlineEn    String
  headlineAr    String
  descriptionEn String
  descriptionAr String
  imageUrl      String
  statsEn       String
  statsAr       String
  whatIsEn      String
  whatIsAr      String
  sortOrder     Int              @default(0)
  instruments   Instrument[]
  advantages    AssetAdvantage[]
  faqs          AssetFaq[]
  // SEO
  metaTitleEn         String?
  metaTitleAr         String?
  metaDescriptionEn   String?
  metaDescriptionAr   String?
  ogImageUrl          String?
  keywords            String?
}

model Instrument {
  id        String         @id @default(cuid())
  nameEn    String
  nameAr    String
  symbol    String
  spread    String
  leverage  String
  hours     String
  sortOrder Int            @default(0)
  assetId   String
  asset     FinancialAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model AssetAdvantage {
  id        String         @id @default(cuid())
  titleEn   String
  titleAr   String
  descEn    String
  descAr    String
  sortOrder Int            @default(0)
  assetId   String
  asset     FinancialAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model AssetFaq {
  id         String         @id @default(cuid())
  questionEn String
  questionAr String
  answerEn   String
  answerAr   String
  sortOrder  Int            @default(0)
  assetId    String
  asset      FinancialAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

// ─── Videos ─────────────────────────────────────────────────────────

model Video {
  id          String   @id @default(cuid())
  videoId     String   @unique
  titleEn     String
  titleAr     String
  descEn      String
  descAr      String
  fullDescEn  String
  fullDescAr  String
  takeawaysEn String
  takeawaysAr String
  linkTextEn  String
  linkTextAr  String
  day         String
  monthEn     String
  monthAr     String
  durationEn  String
  durationAr  String
  videoUrl    String
  labelEn     String   @default("")
  labelAr     String   @default("")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  // SEO
  metaTitleEn         String?
  metaTitleAr         String?
  metaDescriptionEn   String?
  metaDescriptionAr   String?
  ogImageUrl          String?
  keywords            String?
}

// ─── Legal Pages ────────────────────────────────────────────────────

model LegalSection {
  id           String @id @default(cuid())
  pageType     String
  titleEn      String
  titleAr      String
  paragraphsEn String
  paragraphsAr String
  sortOrder    Int    @default(0)
}

// ─── Islamic Rulings ────────────────────────────────────────────────

model IslamicRulingSection {
  id        String              @id @default(cuid())
  nameEn    String
  nameAr    String
  sortOrder Int                 @default(0)
  items     IslamicRulingItem[]
}

model IslamicRulingItem {
  id         String               @id @default(cuid())
  titleEn    String
  titleAr    String
  questionEn String
  questionAr String
  answerEn   String
  answerAr   String
  muftiEn    String
  muftiAr    String
  sortOrder  Int                  @default(0)
  sectionId  String
  section    IslamicRulingSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
}

// ─── Navigation ─────────────────────────────────────────────────────

model NavItem {
  id          String    @id @default(cuid())
  location    String
  labelEn     String
  labelAr     String
  href        String
  hasDropdown Boolean   @default(false)
  sortOrder   Int       @default(0)
  parentId    String?
  parent      NavItem?  @relation("NavChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children    NavItem[] @relation("NavChildren")
}

model SocialIcon {
  id        String @id @default(cuid())
  src       String
  alt       String
  href      String
  sortOrder Int    @default(0)
}

// ─── User ──────────────────────────────────────────────────────────

model User {
  id              String   @id @default(cuid())
  accountId       String   @unique
  email           String
  passwordHash    String
  firstName       String   @default("")
  lastName        String   @default("")
  mobile          String   @default("")
  dateOfBirth     String   @default("")
  address         String   @default("")
  city            String   @default("")
  postalCode      String   @default("")
  country         String   @default("")
  profession      String   @default("")
  additionalPhone String   @default("")
  annualIncome    String   @default("")
  avatar          String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model UserDocument {
  id        String   @id @default(cuid())
  userId    String
  docKey    String
  face      String?
  url       String
  fileName  String
  status    String   @default("Pending") // "Pending", "Approved", "Rejected"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model ContactRequest {
  id           String   @id @default(cuid())
  userId       String?
  firstName    String
  lastName     String
  email        String
  phoneNumber  String
  reason       String
  requestType  String
  topicDetails String
  status       String   @default("New") // "New", "In Progress", "Resolved"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Admin ─────────────────────────────────────────────────────────

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Economic Developments ─────────────────────────────────────────

model EconomicDevelopment {
  id        String   @id @default(cuid())
  slug      String   @unique
  imageUrl  String
  day       String
  monthEn   String
  monthAr   String
  readTimeEn String
  readTimeAr String
  titleEn   String
  titleAr   String
  excerptEn String
  excerptAr String
  bodyEn    String
  bodyAr    String
  featured  Boolean  @default(false)
  published Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // Content fields
  imageAltEn          String?
  imageAltAr          String?
  category            String?
  tags                String?
  // SEO
  metaTitleEn         String?
  metaTitleAr         String?
  metaDescriptionEn   String?
  metaDescriptionAr   String?
  ogImageUrl          String?
  keywords            String?
}

model SuggestedEconomicDevelopment {
  id        String @id @default(cuid())
  imageUrl  String
  titleEn   String
  titleAr   String
  slug      String
  sortOrder Int    @default(0)
}

// ─── Site Images ────────────────────────────────────────────────────

model SiteImage {
  id        String   @id @default(cuid())
  path      String   @unique
  altText   String?
  category  String?
  fileName  String
  mimeType  String?
  sizeBytes Int?
  createdAt DateTime @default(now())
}

// ─── Audit Log ────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String
  adminEmail String
  action     String
  resource   String
  resourceId String?
  details    String?
  ip         String
  createdAt  DateTime @default(now())
}

// ─── Financial Transactions ─────────────────────────────────────────

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @default(now())
  method    String   // "Credit Card", "Bank Transfer", "Internal"
  type      String   // "Deposit", "Withdrawal", "Bonus"
  amount    Float
  currency  String   @default("USD")
  status    String   @default("Pending") // "Completed", "Pending", "Failed"
  reference String?
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
